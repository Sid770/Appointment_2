# Ignore everything by default
*
!*/
!.gitignore

# Only include AppointmentAuthApi folder
!AppointmentAuthApi/
!AppointmentAuthApi/**

# Exclude database files and build artifacts
AppointmentAuthApi/bin/
AppointmentAuthApi/obj/
AppointmentAuthApi/*.db
AppointmentAuthApi/*.db-shm
AppointmentAuthApi/*.db-wal
